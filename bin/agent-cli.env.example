# agent-cli.env — copy to agent-cli.env and edit. Gitignored.
#
# All values are optional; each falls back to the wrapper script's built-in
# default. Env vars OPERATOR_NAME / AGENT_CLI_SSH_KEY / AGENT_CLI_HOST take
# precedence over this file.

# Path to the SSH private key (relative or absolute).
# Default: <repo>/auth cloud/id_ed25519
# SSH_KEY=C:\Dev\agent-platform-roadmap\auth cloud\id_ed25519

# SSH target (user@host).
# Default: webmcp@37.27.188.52
# SSH_HOST=webmcp@37.27.188.52

# Operator identity stamped on every dispatch + audit entry. MUST exist in
# config/operators.yaml — anything else fails with operator_unknown.
# Default: gadofir
# OPERATOR_NAME=gadofir

# In-cluster URL of the dispatch service. Rarely needs changing.
# Default: http://dispatch-http:8080
# DISPATCH_URL=http://dispatch-http:8080

# Kubernetes label selector for the agent pod (the binary host).
# Default: app=agent
# POD_LABEL=app=agent
